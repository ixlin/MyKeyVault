@page
@model MyKeyVault.Web.Areas.Identity.Pages.Account.Manage.DeletePersonalDataModel
@{
    ViewData["Title"] = "删除账户";
}
<h3 class="text-danger">删除账户</h3>
<p>此操作将永久删除账户及所有关联数据，且无法恢复。</p>
<form method="post">
  <div asp-validation-summary="ModelOnly" class="text-danger"></div>
  @if(Model.RequirePassword){
    <div class="form-floating mb-3">
      <input asp-for="Input.Password" class="form-control" type="password" />
      <label asp-for="Input.Password">当前密码</label>
      <span asp-validation-for="Input.Password" class="text-danger"></span>
    </div>
  }
  <button type="submit" class="btn btn-danger">确认删除</button>
  <a asp-page="./PersonalData" class="btn btn-secondary ms-2">返回</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
