{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mykeyvault_dev;Username=postgres;Password=postgres"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUser": "",
    "SmtpPassword": "",
    "FromEmail": "",
    "FromName": "MyKeyVault Development",
    "ThrowOnError": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "WechatScraper": {
    "ServiceUrl": "http://127.0.0.1:5001",
    "OutputPath": "wechat-articles",
    "MaxArticlesPerRequest": 10,
    "BatchArticlesPerTask": 3,
    "MaxActiveTasksPerUser": 1,
    "StalePendingMinutes": 30,
    "StaleProcessingMinutes": 20
  }
}
