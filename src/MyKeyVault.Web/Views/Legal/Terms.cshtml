@{
    ViewData["Title"] = "条款正文";
    var accepted = (bool)(ViewBag.CurrentVersionAccepted ?? false);
    var version = (string)ViewBag.Version;
}
<h1>使用条款（版本 @version）</h1>
<p>请在继续使用前完整阅读。</p>
<h4>1. 数据与风险</h4>
<p>本 v0.1 版本账号/密码仍为明文存储（仅限学习/测试），请勿录入生产级或高度敏感凭证。</p>
<h4>2. 版本升级</h4>
<p>未来引入本地加密/主口令时将提升条款版本，需重新确认。</p>
<h4>3. 用户责任</h4>
<p>你上传内容的合法性与合规性由你自行负责。</p>
@if(!accepted){
<div class="mt-3">
    <form asp-controller="Legal" asp-action="Accept" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-primary">我已阅读并同意</button>
    </form>
</div>
} else {
    <div class="alert alert-success">你已接受当前版本条款。</div>
    <a class="btn btn-outline-secondary" asp-action="Policy">查看记录</a>
}
