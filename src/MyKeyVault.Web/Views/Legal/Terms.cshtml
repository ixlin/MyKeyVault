@{
    ViewData["Title"] = "使用条款";
}
<h1>使用条款</h1>
<p>使用本服务即表示您已阅读并同意以下条款：</p>
<ul>
    <li>本服务仅存储您的加密数据，若遗失主口令将无法恢复数据。</li>
    <li>请妥善保管您的主口令，并确保设备安全。</li>
    <li>您对上传内容的合法性与合规性负责。</li>
</ul>
<p>继续使用即表示您接受本条款。</p>
<div class="mt-3">
    <form asp-controller="Legal" asp-action="Accept" method="post">
        <button type="submit" class="btn btn-primary">我已阅读并同意</button>
        @Html.AntiForgeryToken()
    </form>
    <a class="btn btn-outline-secondary ms-2" asp-controller="Home" asp-action="Index">返回首页</a>
</div>
