@model MyKeyVault.Web.Services.TaskStatusResponseDto
@{
    ViewData["Title"] = "任务进度";
    var taskId = (string)ViewBag.TaskId;
    var currentStage = Model.Articles.FirstOrDefault(a => a.Status == "processing" && !string.IsNullOrWhiteSpace(a.Stage));
}

<div class="container" style="max-width: 900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-arrow-repeat"></i> 任务详情与进度</h2>
        <div>
            <a asp-action="TaskManagement" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i> 返回任务管理
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary me-2">
                <i class="bi bi-file-earmark-text"></i> 查看文章
            </a>
            @if (Model.Status == "completed" || Model.Status == "failed" || Model.Status == "partial")
            {
                <button type="button" class="btn btn-outline-danger" onclick="confirmDeleteTask()">
                    <i class="bi bi-trash"></i> 删除任务
                </button>
            }
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-info-circle"></i> 任务信息</span>
            <span id="taskStatus" class="badge @GetStatusBadgeClass(Model.Status)">@GetStatusText(Model.Status)</span>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label text-muted">Python Task ID</label>
                    <div><code>@taskId</code></div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted">数据库 ID(s)</label>
                    <div>
                        @{
                            var dbArticles = ViewBag.DbArticles as List<MyKeyVault.Web.Models.WechatArticle>;
                            if (dbArticles != null && dbArticles.Any())
                            {
                                foreach (var article in dbArticles)
                                {
                                    <code class="me-2">@article.ArticleId</code>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        }
                    </div>
                </div>
            </div>
            
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label text-muted">创建时间</label>
                    <div>
                        @if (dbArticles != null && dbArticles.Any())
                        {
                            <span>@dbArticles.First().CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted">完成时间</label>
                    <div>
                        @if (dbArticles != null && dbArticles.Any() && dbArticles.First().CompletedAt.HasValue)
                        {
                            <span>@dbArticles.First().CompletedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                        }
                        else if (Model.Status == "completed" || Model.Status == "failed" || Model.Status == "partial")
                        {
                            <span class="text-muted">刚刚完成</span>
                        }
                        else
                        {
                            <span class="text-muted">进行中...</span>
                        }
                    </div>
                </div>
            </div>
            
            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label text-muted">总图片数</label>
                    <div><strong>@Model.Articles.Sum(a => a.ImagesCount)</strong> 张</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted">总视频数</label>
                    <div><strong>@Model.Articles.Sum(a => a.VideosCount)</strong> 个</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted">文章数量</label>
                    <div><strong>@Model.TotalCount</strong> 篇</div>
                </div>
            </div>
            
            <div class="mb-0">
                <label class="form-label text-muted">整体进度</label>
                <div class="progress" style="height: 25px;">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                         role="progressbar" 
                         style="width: @GetOverallProgressPercent(Model)%;"
                         aria-valuenow="@Model.CompletedCount" 
                         aria-valuemin="0" 
                         aria-valuemax="@Model.TotalCount">
                        <span id="progressText">@GetOverallProgressPercent(Model)% (@Model.CompletedCount / @Model.TotalCount)</span>
                    </div>
                </div>
                <div id="taskStage" class="small text-muted mt-1">@(currentStage != null ? $"当前：{(currentStage.Title ?? currentStage.SourceUrl ?? currentStage.ArticleId)} - {currentStage.Stage}" : "")</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <i class="bi bi-list-check"></i> 文章列表
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>文章</th>
                        <th>状态</th>
                        <th>图片</th>
                    </tr>
                </thead>
                <tbody id="articleList">
                    @foreach (var article in Model.Articles)
                    {
                        <tr data-article-id="@article.ArticleId">
                            <td>
                                @if (!string.IsNullOrEmpty(article.Title))
                                {
                                    <div>
                                        <strong>@article.Title</strong>
                                        @if (!string.IsNullOrEmpty(article.Author))
                                        {
                                            <br><small class="text-muted">@article.Author</small>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">处理中...</span>
                                    <br><small class="text-muted">@article.SourceUrl</small>
                                }
                            </td>
                            <td class="article-status">
                                @Html.Raw(GetStatusHtml(article.Status, article.ErrorMessage))
                                @if (!string.IsNullOrWhiteSpace(article.Stage))
                                {
                                    <div class="small text-muted mt-1">@article.Stage</div>
                                }
                                @if (!string.IsNullOrEmpty(article.ErrorMessage))
                                {
                                    <div class="text-danger small mt-1" style="white-space: pre-wrap;">
                                        @article.ErrorMessage
                                    </div>
                                }
                            </td>
                            <td class="article-images">@article.ImagesCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 text-center" id="actionButtons">
        @if (Model.Status == "completed" || Model.Status == "partial")
        {
            <a asp-action="Index" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> 查看全部文章
            </a>
        }
        else
        {
            <p class="text-muted">
                <span class="spinner-border spinner-border-sm"></span>
                正在爬取中，请稍候...
            </p>
        }
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script>
        const taskId = '@taskId';
        let pollInterval = null;
        
        function updateUI(data) {
            // 更新状态徽章
            const statusBadge = document.getElementById('taskStatus');
            statusBadge.className = 'badge ' + getStatusBadgeClass(data.status);
            statusBadge.textContent = getStatusText(data.status);
            
            // 更新进度条
            const percent = getOverallProgressPercent(data);
            const progressBar = document.getElementById('progressBar');
            progressBar.style.width = percent + '%';
            document.getElementById('progressText').textContent = percent + '% (' + data.completed_count + ' / ' + data.total_count + ')';

            // 更新任务阶段（取第一篇 processing 且有 stage 的文章）
            const taskStage = document.getElementById('taskStage');
            const processing = (data.articles || []).find(a => a.status === 'processing' && a.stage);
            if (processing && processing.stage) {
                const who = processing.title || processing.source_url || processing.article_id;
                taskStage.textContent = `当前：${who} - ${processing.stage}`;
            } else {
                taskStage.textContent = '';
            }
            
            // 更新文章列表
            data.articles.forEach(article => {
                const row = document.querySelector(`tr[data-article-id="${article.article_id}"]`);
                if (row) {
                    const titleCell = row.querySelector('td:first-child');
                    if (article.title) {
                        const title = escapeHtml(article.title);
                        const author = article.author ? escapeHtml(article.author) : '';
                        titleCell.innerHTML = `<div><strong>${title}</strong>${author ? '<br><small class="text-muted">' + author + '</small>' : ''}</div>`;
                    }
                    
                    row.querySelector('.article-status').innerHTML = renderArticleStatus(article);
                    row.querySelector('.article-images').textContent = article.images_count;
                }
            });
            
            // 完成时停止轮询
            if (data.status === 'completed' || data.status === 'failed' || data.status === 'partial') {
                if (pollInterval) {
                    clearInterval(pollInterval);
                    pollInterval = null;
                }
                
                // 更新按钮
                const actionButtons = document.getElementById('actionButtons');
                actionButtons.innerHTML = '<a href="/WechatArticle" class="btn btn-primary"><i class="bi bi-check-circle"></i> 查看全部文章</a>';
                
                // 移除进度条动画
                progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
            }
        }

        function escapeHtml(str) {
            if (str === null || str === undefined) return '';
            return String(str)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');
        }

        function getOverallProgressPercent(data) {
            const total = Number(data.total_count || 0);
            const articles = Array.isArray(data.articles) ? data.articles : [];
            if (total <= 0) return 0;

            // 用每篇文章进度的平均值做总进度（这样中间会持续增长）
            // completed/failed 视为 100；pending 无 progress 视为 0。
            let sum = 0;
            for (const a of articles) {
                if (a.status === 'completed' || a.status === 'failed') {
                    sum += 100;
                    continue;
                }
                const pRaw = a.progress;
                const p = (pRaw === null || pRaw === undefined) ? 0 : Number(pRaw);
                if (Number.isNaN(p)) {
                    sum += 0;
                } else {
                    sum += Math.max(0, Math.min(100, p));
                }
            }

            // 兼容后端偶尔不返回 articles 的情况
            if (articles.length === 0) {
                return Math.round((Number(data.completed_count || 0) / total) * 100);
            }

            return Math.round(sum / total);
        }
        
        function getStatusBadgeClass(status) {
            switch (status) {
                case 'completed': return 'bg-success';
                case 'processing': return 'bg-primary';
                case 'pending': return 'bg-secondary';
                case 'failed': return 'bg-danger';
                case 'partial': return 'bg-warning';
                default: return 'bg-secondary';
            }
        }
        
        function getStatusText(status) {
            switch (status) {
                case 'completed': return '已完成';
                case 'processing': return '处理中';
                case 'pending': return '等待中';
                case 'failed': return '失败';
                case 'partial': return '部分完成';
                default: return status;
            }
        }
        
        function getStatusHtml(status, errorMessage) {
            switch (status) {
                case 'completed': 
                    return '<span class="badge bg-success">已完成</span>';
                case 'processing': 
                    return '<span class="badge bg-primary"><span class="spinner-border spinner-border-sm"></span> 处理中</span>';
                case 'pending': 
                    return '<span class="badge bg-secondary">等待中</span>';
                case 'failed': 
                    return `<span class="badge bg-danger" title="${escapeHtml(errorMessage || '')}">失败</span>`;
                default: 
                    return `<span class="badge bg-secondary">${status}</span>`;
            }
        }

        function renderArticleStatus(article) {
            const statusHtml = getStatusHtml(article.status, article.error_message);

            const stageHtml = article.stage
                ? `<div class="small text-muted mt-1">${escapeHtml(article.stage)}</div>`
                : '';

            const errorHtml = article.error_message
                ? `<div class="text-danger small mt-1" style="white-space: pre-wrap;">${escapeHtml(article.error_message)}</div>`
                : '';

            return statusHtml + stageHtml + errorHtml;
        }
        
        async function pollStatus() {
            try {
                const response = await fetch(`/WechatArticle/GetTaskStatus?taskId=${taskId}`);
                if (response.ok) {
                    const data = await response.json();
                    updateUI(data);
                }
            } catch (error) {
                console.error('获取状态失败:', error);
            }
        }
        
        // 初始状态检查
        const initialStatus = '@Model.Status';
        if (initialStatus !== 'completed' && initialStatus !== 'failed' && initialStatus !== 'partial') {
            // 每 3 秒轮询一次
            pollInterval = setInterval(pollStatus, 3000);
        }
        
        // 确认删除任务
        function confirmDeleteTask() {
            if (confirm('确定要删除此任务吗？\n\n此操作将：\n• 强制停止正在运行的抓取进程\n• 删除已下载的文件和目录\n• 删除所有相关数据库记录\n• 记录此操作到审计日志\n\n此操作不可恢复！')) {
                deleteTask();
            }
        }
        
        // 删除任务
        async function deleteTask() {
            try {
                const response = await fetch('@Url.Action("DeleteTaskFromDetail")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ taskId: taskId })
                });
                
                if (response.ok) {
                    alert('任务删除成功');
                    window.location.href = '@Url.Action("TaskManagement")';
                } else {
                    const result = await response.json();
                    alert(result.error || '删除失败');
                }
            } catch (error) {
                console.error('删除失败:', error);
                alert('删除请求失败，请重试');
            }
        }
    </script>
}

@functions {
    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "completed" => "bg-success",
            "processing" => "bg-primary",
            "pending" => "bg-secondary",
            "failed" => "bg-danger",
            "partial" => "bg-warning",
            _ => "bg-secondary"
        };
    }
    
    string GetStatusText(string status)
    {
        return status switch
        {
            "completed" => "已完成",
            "processing" => "处理中",
            "pending" => "等待中",
            "failed" => "失败",
            "partial" => "部分完成",
            _ => status
        };
    }
    
    int GetProgressPercent(MyKeyVault.Web.Services.TaskStatusResponseDto model)
    {
        if (model.TotalCount == 0) return 0;
        return (int)Math.Round((double)model.CompletedCount / model.TotalCount * 100);
    }

    int GetOverallProgressPercent(MyKeyVault.Web.Services.TaskStatusResponseDto model)
    {
        if (model.TotalCount == 0) return 0;

        if (model.Articles == null || model.Articles.Count == 0)
        {
            return GetProgressPercent(model);
        }

        var sum = 0;
        foreach (var a in model.Articles)
        {
            if (a.Status == "completed" || a.Status == "failed")
            {
                sum += 100;
                continue;
            }

            if (a.Progress.HasValue)
            {
                sum += Math.Clamp(a.Progress.Value, 0, 100);
            }
        }

        return (int)Math.Round((double)sum / model.TotalCount);
    }
    
    string GetStatusHtml(string status, string? errorMessage)
    {
        return status switch
        {
            "completed" => "<span class=\"badge bg-success\">已完成</span>",
            "processing" => "<span class=\"badge bg-primary\"><span class=\"spinner-border spinner-border-sm\"></span> 处理中</span>",
            "pending" => "<span class=\"badge bg-secondary\">等待中</span>",
            "failed" => $"<span class=\"badge bg-danger\" title=\"{errorMessage ?? ""}\">失败</span>",
            _ => $"<span class=\"badge bg-secondary\">{status}</span>"
        };
    }
}
