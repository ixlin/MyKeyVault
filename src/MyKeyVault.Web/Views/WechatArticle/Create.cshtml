@{
    ViewData["Title"] = "新建爬取任务";
    var serviceAvailable = (bool)ViewBag.ServiceAvailable;
}

<div class="container" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-plus-circle"></i> 新建爬取任务</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> 返回列表
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!serviceAvailable)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-octagon"></i>
            <strong>爬虫服务不可用</strong>
            <p class="mb-0 mt-2">无法创建新任务，请稍后重试或联系管理员。</p>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="urls" class="form-label">
                            微信公众号文章链接
                            <small class="text-muted">(每行一个，最多 10 个)</small>
                        </label>
                        <textarea class="form-control" id="urls" name="urls" rows="8" 
                                  placeholder="https://mp.weixin.qq.com/s/xxxxx&#10;https://mp.weixin.qq.com/s/yyyyy&#10;..."
                                  required></textarea>
                        <div class="form-text">
                            <i class="bi bi-info-circle"></i>
                            支持的链接格式：
                            <code>https://mp.weixin.qq.com/s/xxxxx</code> 或
                            <code>https://mp.weixin.qq.com/s?__biz=...</code>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="confirmCheck" required>
                            <label class="form-check-label" for="confirmCheck">
                                我确认这些链接是公开可访问的微信公众号文章
                            </label>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="bi bi-cloud-download"></i> 开始爬取
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <i class="bi bi-question-circle"></i> 使用说明
            </div>
            <div class="card-body">
                <ul class="mb-0">
                    <li>每次最多提交 <strong>10 个</strong> 链接</li>
                    <li>爬取过程可能需要 1-2 分钟，请耐心等待</li>
                    <li>爬取完成后，可以预览文章或下载完整文件包</li>
                    <li>下载包包含 HTML 文件和所有图片资源</li>
                    <li>请遵守微信公众平台使用条款，仅用于个人学习</li>
                </ul>
            </div>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script>
        (() => {
            const urlsEl = document.getElementById('urls');
            if (!urlsEl) return;

            let checkUrlTimeout = null;
            let lastCheckedKey = '';

            function clearWarnings() {
                const existing = document.getElementById('url-warning');
                if (existing) existing.remove();
            }

            function displayExistingWarnings(results) {
                clearWarnings();

                const entries = Object.entries(results ?? {}).filter(([, info]) => info && info.exists);
                if (entries.length === 0) return;

                const warningDiv = document.createElement('div');
                warningDiv.id = 'url-warning';
                warningDiv.className = 'alert alert-warning mt-2';

                const header = `<div><strong>发现 ${entries.length} 个链接重复爬取：</strong></div>`;
                const bodyLines = entries.map(([, info]) => {
                    const article = info.article;
                    if (!article) return '';

                    const title = (article.title || '(无标题)').toString();
                    const timeText = (article.completedAt || '').toString();
                    const href = `@Url.Action("Index", "WechatArticle")?highlight=${article.id}`;

                    return `
                        <div>
                            <span class="text-truncate d-inline-block" style="max-width: 520px;" title="${escapeHtml(title)}">${escapeHtml(title)}</span>
                            <small class="text-muted ms-2">${escapeHtml(timeText)}</small>
                            <a href="${href}" class="ms-2 small" target="_blank">查看</a>
                        </div>
                    `;
                }).join('');

                warningDiv.innerHTML = `${header}<div class="mt-1">${bodyLines}</div>`;

                const parent = urlsEl.parentNode;
                parent.insertBefore(warningDiv, urlsEl.nextSibling);
            }

            function escapeHtml(text) {
                return text
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            async function checkExistingUrls(urls) {
                const validUrls = urls.filter(u => u.includes('mp.weixin.qq.com'));
                if (validUrls.length === 0) {
                    clearWarnings();
                    return;
                }

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const headers = { 'Content-Type': 'application/json' };
                    if (token) headers['RequestVerificationToken'] = token;

                    const response = await fetch('@Url.Action("CheckUrls", "WechatArticle")', {
                        method: 'POST',
                        headers,
                        body: JSON.stringify({ urls: validUrls })
                    });

                    if (!response.ok) {
                        console.error('检查URL失败:', response.status, response.statusText);
                        return;
                    }

                    const data = await response.json();
                    displayExistingWarnings(data?.results ?? {});
                } catch (error) {
                    console.error('检查URL出错:', error);
                }
            }

            urlsEl.addEventListener('input', function () {
                const lines = this.value
                    .split('\n')
                    .map(l => l.trim())
                    .filter(Boolean);

                // 用“有效行”生成稳定 key：尾部回车/空行不会导致 key 变化
                const currentKey = lines.join('\n');

                const submitBtn = document.getElementById('submitBtn');
                if (submitBtn) {
                    if (lines.length > 10) {
                        submitBtn.disabled = true;
                        submitBtn.innerHTML = '<i class="bi bi-exclamation-circle"></i> 超过 10 个链接';
                    } else {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="bi bi-cloud-download"></i> 开始爬取';
                    }
                }

                if (checkUrlTimeout) clearTimeout(checkUrlTimeout);

                // 没有有效链接：清空提示并重置状态
                if (!currentKey) {
                    clearWarnings();
                    lastCheckedKey = '';
                    return;
                }

                // key 未变化：不清空、不重查（避免“按回车提示消失”）
                if (currentKey === lastCheckedKey) {
                    return;
                }

                // key 变化：清除旧提示，然后防抖重查
                clearWarnings();

                if (currentKey !== lastCheckedKey) {
                    checkUrlTimeout = setTimeout(() => {
                        checkExistingUrls(lines);
                        lastCheckedKey = currentKey;
                    }, 600);
                }
            });

            document.querySelector('form')?.addEventListener('submit', function (e) {
                const urls = document.getElementById('urls').value;
                const lines = urls.split('\n').filter(l => l.trim().length > 0);

                const invalidUrls = lines.filter(url => !url.includes('mp.weixin.qq.com'));
                if (invalidUrls.length > 0) {
                    e.preventDefault();
                    alert('发现无效的链接,请确保所有链接都是微信公众号文章地址(包含 mp.weixin.qq.com)');
                    return false;
                }
            });
        })();
    </script>
}
