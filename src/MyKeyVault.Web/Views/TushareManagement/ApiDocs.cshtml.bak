@{
    ViewData["Title"] = "API 文档";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<link rel="stylesheet" href="~/css/sap-ui.css" />

<div class="sap-page">
    <div class="container">
        <div class="sap-object-page">
            <div class="sap-object-header">
                <h2>API 使用文档</h2>
                <div class="subtitle">Tushare 数据服务 API 调用指南</div>
            </div>

            <div class="sap-toolbar">
                <div></div>
                <div>
                    <a href="@Url.Action("Apps")" class="sap-button sap-button-secondary">返回应用管理</a>
                </div>
            </div>

            <div style="padding: 2rem;">
                <!-- 认证接口 -->
                <div class="sap-card">
                    <div class="sap-card-header">1. 获取访问令牌</div>
                    <p style="color: #6a6d70; margin-bottom: 1rem;">使用 AppId 和 AppSecret 获取访问令牌</p>
                    
                    <div style="margin-bottom: 1rem;">
                        <strong>请求地址：</strong>
                        <code style="background: #f7f7f7; padding: 0.25rem 0.5rem; border-radius: 4px;">POST @baseUrl/api/tushare/auth/token</code>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <strong>请求示例：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>{
  "appId": "app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
  "appSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=="
}</code></pre>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <strong>响应示例：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>{
  "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
  "expiresIn": 7200,
  "tokenType": "Bearer"
}</code></pre>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <strong>cURL 测试：</strong>
                        <pre style="background: #2d2d2d; color: #f8f8f2; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>curl -X POST @baseUrl/api/tushare/auth/token \
  -H "Content-Type: application/json" \
  -d '{
    "appId": "你的AppId",
    "appSecret": "你的AppSecret"
  }'</code></pre>
                    </div>
                </div>

                <!-- 查询接口 -->
                <div class="sap-card">
                    <div class="sap-card-header">2. 查询数据</div>
                    <p style="color: #6a6d70; margin-bottom: 1rem;">使用访问令牌查询 Tushare 数据</p>
                    
                    <div style="margin-bottom: 1rem;">
                        <strong>请求地址：</strong>
                        <code style="background: #f7f7f7; padding: 0.25rem 0.5rem; border-radius: 4px;">POST @baseUrl/api/tushare/query</code>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <strong>请求头：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px;"><code>Authorization: Bearer {accessToken}
Content-Type: application/json</code></pre>
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <strong>请求体结构：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>{
  "apiName": "接口名称",
  "params": {
    "参数名": "参数值"
  },
  "forceRefresh": false  // 可选，是否强制刷新数据
}</code></pre>
                    </div>
                </div>

                <!-- 支持的接口 -->
                <div class="sap-card">
                    <div class="sap-card-header">3. 支持的接口列表</div>
                    
                    <table class="sap-table" style="margin-top: 1rem;">
                        <thead>
                            <tr>
                                <th>接口名称</th>
                                <th>说明</th>
                                <th>主要参数</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>stock_basic</code></td>
                                <td>股票列表</td>
                                <td><code>list_status</code>: L=上市, D=退市, P=暂停</td>
                            </tr>
                            <tr>
                                <td><code>daily</code></td>
                                <td>日线行情</td>
                                <td><code>ts_code</code>: 股票代码<br/>
                                    <code>trade_date</code>: 交易日期(yyyyMMdd)<br/>
                                    或 <code>start_date</code> + <code>end_date</code></td>
                            </tr>
                            <tr>
                                <td><code>income</code></td>
                                <td>利润表</td>
                                <td><code>ts_code</code>: 股票代码</td>
                            </tr>
                            <tr>
                                <td><code>balancesheet</code></td>
                                <td>资产负债表</td>
                                <td><code>ts_code</code>: 股票代码</td>
                            </tr>
                            <tr>
                                <td><code>cashflow</code></td>
                                <td>现金流量表</td>
                                <td><code>ts_code</code>: 股票代码</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- 示例 -->
                <div class="sap-card">
                    <div class="sap-card-header">4. 完整调用示例</div>
                    
                    <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">示例 1：获取股票列表</h4>
                    <pre style="background: #2d2d2d; color: #f8f8f2; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {你的token}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "stock_basic",
    "params": {
      "list_status": "L"
    }
  }'</code></pre>

                    <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">示例 2：查询平安银行日线数据</h4>
                    <pre style="background: #2d2d2d; color: #f8f8f2; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {你的token}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "daily",
    "params": {
      "ts_code": "000001.SZ",
      "start_date": "20250101",
      "end_date": "20250110"
    }
  }'</code></pre>

                    <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">示例 3：查询贵州茅台利润表</h4>
                    <pre style="background: #2d2d2d; color: #f8f8f2; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {你的token}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "income",
    "params": {
      "ts_code": "600519.SH"
    }
  }'</code></pre>
                </div>

                <!-- 响应格式 -->
                <div class="sap-card">
                    <div class="sap-card-header">5. 响应格式</div>
                    
                    <div style="margin-bottom: 1rem;">
                        <strong>成功响应：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>{
  "code": 0,
  "message": "success",
  "data": [ /* 数据数组 */ ],
  "requestId": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
  "partial": false,
  "missingItems": []
}</code></pre>
                    </div>

                    <div>
                        <strong>错误响应：</strong>
                        <pre style="background: #f7f7f7; padding: 1rem; border-radius: 4px; overflow-x: auto;"><code>{
  "code": 500,
  "message": "错误信息",
  "requestId": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
}</code></pre>
                    </div>
                </div>

                <!-- 注意事项 -->
                <div class="sap-card">
                    <div class="sap-card-header">6. 注意事项</div>
                    <ul style="color: #6a6d70; line-height: 1.8;">
                        <li>访问令牌有效期为 2 小时，过期后需重新获取</li>
                        <li>日期格式统一为 <code>yyyyMMdd</code>，如 <code>20250110</code></li>
                        <li>股票代码格式：上海交易所以 <code>.SH</code> 结尾，深圳交易所以 <code>.SZ</code> 结尾</li>
                        <li>历史数据首次查询会从 Tushare 获取并缓存，后续直接从本地数据库返回</li>
                        <li>如需强制刷新数据，设置 <code>forceRefresh: true</code></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
