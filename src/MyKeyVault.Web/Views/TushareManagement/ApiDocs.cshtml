@{
    ViewData["Title"] = "API 文档";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}

<link rel="stylesheet" href="~/css/sap-ui.css" />

<style>
    .api-docs-container {
        display: flex;
        height: calc(100vh - 200px);
        gap: 1rem;
    }
    
    .api-sidebar {
        width: 280px;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        overflow-y: auto;
    }
    
    .api-content {
        flex: 1;
        background: #fff;
        border: 1px solid #e5e5e5;
        border-radius: 4px;
        padding: 2rem;
        overflow-y: auto;
    }
    
    .api-nav-section {
        padding: 1rem 0;
        border-bottom: 1px solid #e5e5e5;
    }
    
    .api-nav-title {
        padding: 0 1rem;
        font-weight: 600;
        font-size: 13px;
        color: #32363a;
        margin-bottom: 0.5rem;
    }
    
    .api-nav-item {
        padding: 0.5rem 1rem;
        cursor: pointer;
        font-size: 14px;
        color: #32363a;
        transition: background 0.2s;
    }
    
    .api-nav-item:hover {
        background: #f7f7f7;
    }
    
    .api-nav-item.active {
        background: #0a6ed1;
        color: #fff;
        font-weight: 600;
    }
    
    .api-section {
        display: none;
    }
    
    .api-section.active {
        display: block;
    }
    
    .param-table {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
    }
    
    .param-table th,
    .param-table td {
        border: 1px solid #e5e5e5;
        padding: 0.75rem;
        text-align: left;
    }
    
    .param-table th {
        background: #f7f7f7;
        font-weight: 600;
    }
    
    .code-block {
        background: #2d2d2d;
        color: #f8f8f2;
        padding: 1rem;
        border-radius: 4px;
        overflow-x: auto;
        margin: 0.5rem 0;
    }
    
    .inline-code {
        background: #f7f7f7;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-family: monospace;
        font-size: 13px;
    }
</style>

<div class="sap-page">
    <div class="container">
        <div class="sap-object-page">
            <div class="sap-object-header">
                <h2>API 使用文档</h2>
                <div class="subtitle">Tushare 数据服务 API 调用指南</div>
            </div>

            <div class="sap-toolbar">
                <div></div>
                <div>
                    <a href="@Url.Action("Apps")" class="sap-button sap-button-secondary">返回应用管理</a>
                </div>
            </div>

            <div class="api-docs-container" style="padding: 1rem;">
                <!-- 左侧导航 -->
                <div class="api-sidebar">
                    <div class="api-nav-section">
                        <div class="api-nav-title">快速开始</div>
                        <div class="api-nav-item active" onclick="showSection('changelog')">更新记录</div>
                        <div class="api-nav-item" onclick="showSection('auth')">获取访问令牌</div>
                    </div>
                    
                    <div class="api-nav-section">
                        <div class="api-nav-title">数据查询接口</div>
                        <div class="api-nav-item" onclick="showSection('stock-basic')">stock_basic - 股票列表</div>
                        <div class="api-nav-item" onclick="showSection('daily')">daily - 日线行情</div>
                        <div class="api-nav-item" onclick="showSection('income')">income - 利润表</div>
                        <div class="api-nav-item" onclick="showSection('balancesheet')">balancesheet - 资产负债表</div>
                        <div class="api-nav-item" onclick="showSection('cashflow')">cashflow - 现金流量表</div>
                    </div>
                    
                    <div class="api-nav-section">
                        <div class="api-nav-title">其他</div>
                        <div class="api-nav-item" onclick="showSection('errors')">错误码说明</div>
                    </div>
                </div>

                <!-- 右侧内容 -->
                <div class="api-content">
                    <!-- 更新记录 -->
                    <div id="changelog" class="api-section active">
                        <h3>更新记录</h3>
                        
                        <h4 style="margin-top: 2rem; color: #0a6ed1;">v1.2.0 - 2025-11-12</h4>
                        <ul>
                            <li>✨ <strong>重要更新</strong>：三大财务报表字段全面对齐 Tushare 官方接口</li>
                            <li>📊 <strong>利润表</strong>：字段从 19 个扩充至 <strong>81 个</strong>，新增成本费用明细、盈利分配、保险银行专属字段等</li>
                            <li>📊 <strong>资产负债表</strong>：字段从 22 个扩充至 <strong>136 个</strong>，新增详细资产负债分类、金融机构专属字段等</li>
                            <li>📊 <strong>现金流量表</strong>：字段从 19 个扩充至 <strong>104 个</strong>，新增经营/投资/筹资活动详细流水、间接法补充数据等</li>
                            <li>📝 <strong>文档完善</strong>：为每个接口添加完整的返回字段说明（包含字段名、类型、中文含义）</li>
                            <li>🔧 <strong>数据类型优化</strong>：所有字段类型与 Tushare 官方接口完全一致</li>
                            <li>🗄️ <strong>数据库更新</strong>：自动迁移脚本已生成，支持增量更新现有数据</li>
                        </ul>
                        
                        <h4 style="margin-top: 2rem; color: #0a6ed1;">v1.1.0 - 2025-11-11</h4>
                        <ul>
                            <li>✨ <strong>新增</strong>：财务报表查询支持 <code class="inline-code">period</code> 参数，可精确查询指定报告期（如 2024年年报）</li>
                            <li>✨ <strong>新增</strong>：支持 <code class="inline-code">start_date</code> + <code class="inline-code">end_date</code> 范围查询</li>
                            <li>🔧 <strong>优化</strong>：本地缓存判断逻辑，按报告期精确匹配，避免返回过期数据</li>
                            <li>🐛 <strong>修复</strong>：财务报表 duplicate key 错误，改为真正的 upsert 逻辑</li>
                            <li>🔧 <strong>优化</strong>：Token 过期自动提示，有效期 2 小时</li>
                        </ul>
                        
                        <h4 style="margin-top: 2rem; color: #0a6ed1;">v1.0.0 - 2025-11-10</h4>
                        <ul>
                            <li>🎉 首次发布</li>
                            <li>✨ 支持 AppId/AppSecret 认证机制</li>
                            <li>✨ 支持股票列表、日线行情、三大财务报表查询</li>
                            <li>✨ 本地数据库缓存，按需持久化</li>
                            <li>✨ JWT 令牌机制，有效期 2 小时</li>
                        </ul>
                    </div>

                    <!-- 获取访问令牌 -->
                    <div id="auth" class="api-section">
                        <h3>获取访问令牌</h3>
                        <p style="color: #6a6d70;">使用 AppId 和 AppSecret 获取 JWT 访问令牌，令牌有效期为 2 小时。</p>
                        
                        <h4 style="margin-top: 2rem;">请求地址</h4>
                        <div class="code-block">POST @baseUrl/api/tushare/auth/token</div>
                        
                        <h4 style="margin-top: 2rem;">请求参数</h4>
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 120px;">参数名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th style="width: 80px;">必填</th>
                                    <th>说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="inline-code">appId</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>应用 ID，在"应用管理"页面创建</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">appSecret</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>应用密钥，创建应用时显示（仅一次）</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <h4 style="margin-top: 2rem;">请求示例</h4>
                        <div class="code-block">curl -X POST @baseUrl/api/tushare/auth/token \
  -H "Content-Type: application/json" \
  -d '{
    "appId": "app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "appSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=="
  }'</div>
                        
                        <h4 style="margin-top: 2rem;">响应示例</h4>
                        <div class="code-block">{
  "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
  "expiresIn": 7200,
  "tokenType": "Bearer"
}</div>
                        
                        <h4 style="margin-top: 2rem;">返回参数</h4>
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 150px;">参数名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th>说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="inline-code">accessToken</code></td>
                                    <td>string</td>
                                    <td>访问令牌，后续请求需要在 Authorization 头中携带</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">expiresIn</code></td>
                                    <td>number</td>
                                    <td>令牌有效期（秒），默认 7200（2小时）</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">tokenType</code></td>
                                    <td>string</td>
                                    <td>令牌类型，固定为 "Bearer"</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- stock_basic -->
                    <div id="stock-basic" class="api-section">
                        <h3>stock_basic - 股票列表</h3>
                        <p style="color: #6a6d70;">获取沪深A股、港股、美股等股票的基本信息。</p>
                        
                        <h4 style="margin-top: 2rem;">请求地址</h4>
                        <div class="code-block">POST @baseUrl/api/tushare/query</div>
                        
                        <h4 style="margin-top: 2rem;">请求头</h4>
                        <div class="code-block">Authorization: Bearer {accessToken}
Content-Type: application/json</div>
                        
                        <h4 style="margin-top: 2rem;">请求参数</h4>
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 150px;">参数名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th style="width: 80px;">必填</th>
                                    <th>说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="inline-code">apiName</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>固定值: <code class="inline-code">stock_basic</code></td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.list_status</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td>上市状态：L=上市 D=退市 P=暂停上市，默认L</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.exchange</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td>交易所：SSE=上交所 SZSE=深交所</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">forceRefresh</code></td>
                                    <td>boolean</td>
                                    <td>否</td>
                                    <td>是否强制刷新，默认false（优先使用本地缓存）</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <h4 style="margin-top: 2rem;">请求示例</h4>
                        <div class="code-block">curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {accessToken}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "stock_basic",
    "params": {
      "list_status": "L"
    },
    "forceRefresh": false
  }'</div>
                        
                        <h4 style="margin-top: 2rem;">响应示例</h4>
                        <div class="code-block">{
  "code": 0,
  "message": "success",
  "data": [
    {
      "tsCode": "000001.SZ",
      "symbol": "000001",
      "name": "平安银行",
      "area": "深圳",
      "industry": "银行",
      "market": "主板",
      "listDate": "1991-04-03"
    }
  ],
  "requestId": "...",
  "partial": false
}</div>
                    </div>

                    <!-- daily -->
                    <div id="daily" class="api-section">
                        <h3>daily - 日线行情</h3>
                        <p style="color: #6a6d70;">获取股票的日线行情数据（OHLC + 成交量成交额）。</p>
                        
                        <h4 style="margin-top: 2rem;">请求参数</h4>
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 150px;">参数名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th style="width: 80px;">必填</th>
                                    <th>说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="inline-code">apiName</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>固定值: <code class="inline-code">daily</code></td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.ts_code</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>股票代码，如 000001.SZ</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.trade_date</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td>交易日期（yyyyMMdd），如 20250110</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.start_date</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td>开始日期（yyyyMMdd），与 end_date 配合使用</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.end_date</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td>结束日期（yyyyMMdd）</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <h4 style="margin-top: 2rem;">请求示例</h4>
                        <div class="code-block">curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {accessToken}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "daily",
    "params": {
      "ts_code": "000001.SZ",
      "start_date": "20250101",
      "end_date": "20250110"
    }
  }'</div>
                        
                        <h4 style="margin-top: 2rem;">响应示例</h4>
                        <div class="code-block">{
  "code": 0,
  "message": "success",
  "data": [
    {
      "tsCode": "000001.SZ",
      "tradeDate": "2025-01-10",
      "open": 12.50,
      "high": 12.80,
      "low": 12.40,
      "close": 12.70,
      "volume": 1000000.0,
      "amount": 12600000.0
    }
  ]
}</div>
                    </div>

                    <!-- income -->
                    <div id="income" class="api-section">
                        <h3>income - 利润表</h3>
                        <p style="color: #6a6d70;">获取上市公司的利润表数据。</p>
                        
                        <h4 style="margin-top: 2rem;">请求参数</h4>
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 150px;">参数名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th style="width: 80px;">必填</th>
                                    <th>说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><code class="inline-code">apiName</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>固定值: <code class="inline-code">income</code></td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.ts_code</code></td>
                                    <td>string</td>
                                    <td>是</td>
                                    <td>股票代码，如 600519.SH</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.period</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td><span style="color: #107e3e; font-weight: 600;">✨新增</span> 报告期（yyyyMMdd），精确查询某期报告<br/>
                                        例如：20241231（2024年年报）、20240630（2024年半年报）</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.start_date</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td><span style="color: #107e3e; font-weight: 600;">✨新增</span> 开始报告期（yyyyMMdd），与 end_date 配合使用</td>
                                </tr>
                                <tr>
                                    <td><code class="inline-code">params.end_date</code></td>
                                    <td>string</td>
                                    <td>否</td>
                                    <td><span style="color: #107e3e; font-weight: 600;">✨新增</span> 结束报告期（yyyyMMdd）</td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <h4 style="margin-top: 2rem;">报告期说明</h4>
                        <ul style="color: #6a6d70;">
                            <li>一季报：<code class="inline-code">20240331</code></li>
                            <li>半年报：<code class="inline-code">20240630</code></li>
                            <li>三季报：<code class="inline-code">20240930</code></li>
                            <li>年报：<code class="inline-code">20241231</code></li>
                        </ul>
                        
                        <h4 style="margin-top: 2rem;">请求示例 1：查询 2024年年报</h4>
                        <div class="code-block">curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {accessToken}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "income",
    "params": {
      "ts_code": "600519.SH",
      "period": "20241231"
    }
  }'</div>
                        
                        <h4 style="margin-top: 2rem;">请求示例 2：查询 2024年全年报告</h4>
                        <div class="code-block">curl -X POST @baseUrl/api/tushare/query \
  -H "Authorization: Bearer {accessToken}" \
  -H "Content-Type: application/json" \
  -d '{
    "apiName": "income",
    "params": {
      "ts_code": "600519.SH",
      "start_date": "20240101",
      "end_date": "20241231"
    }
  }'</div>
                        
                        <h4 style="margin-top: 2rem;">响应示例</h4>
                        <div class="code-block">{
  "code": 0,
  "message": "success",
  "data": [
    {
      "tsCode": "600519.SH",
      "endDate": "2024-12-31",
      "totalRevenue": 150000000000.0,
      "netProfit": 50000000000.0,
      "basicEps": 40.50
    }
  ]
}</div>
                        
                        <h4 style="margin-top: 2rem;">返回字段说明（共 81 个字段）</h4>
                        <p style="color: #6a6d70;">以下为完整的利润表返回字段，所有金额单位为<strong>元</strong>。</p>
                        
                        <table class="param-table">
                            <thead>
                                <tr>
                                    <th style="width: 180px;">字段名</th>
                                    <th style="width: 100px;">类型</th>
                                    <th>中文说明</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td colspan="3" style="background: #f0f0f0; font-weight: 600;">基本信息</td></tr>
                                <tr><td><code class="inline-code">tsCode</code></td><td>string</td><td>股票代码</td></tr>
                                <tr><td><code class="inline-code">annDate</code></td><td>string</td><td>公告日期（格式：YYYYMMDD）</td></tr>
                                <tr><td><code class="inline-code">fAnnDate</code></td><td>string</td><td>实际公告日期（格式：YYYYMMDD）</td></tr>
                                <tr><td><code class="inline-code">endDate</code></td><td>date</td><td>报告期</td></tr>
                                <tr><td><code class="inline-code">reportType</code></td><td>string</td><td>报告类型：1-合并报表 2-单季合并 3-调整单季合并 5-调整合并报表</td></tr>
                                <tr><td><code class="inline-code">compType</code></td><td>string</td><td>公司类型：1-一般工商业 2-银行 3-保险 4-证券</td></tr>
                                <tr><td><code class="inline-code">endType</code></td><td>string</td><td>报告期类型</td></tr>
                                <tr><td><code class="inline-code">updateFlag</code></td><td>string</td><td>更新标识</td></tr>
                                
                                <tr><td colspan="3" style="background: #f0f0f0; font-weight: 600;">收入类</td></tr>
                                <tr><td><code class="inline-code">totalRevenue</code></td><td>decimal</td><td>营业总收入</td></tr>
                                <tr><td><code class="inline-code">revenue</code></td><td>decimal</td><td>营业收入</td></tr>
                                <tr><td><code class="inline-code">intIncome</code></td><td>decimal</td><td>利息收入</td></tr>
                                <tr><td><code class="inline-code">premEarned</code></td><td>decimal</td><td>已赚保费</td></tr>
                                <tr><td><code class="inline-code">commIncome</code></td><td>decimal</td><td>手续费及佣金收入</td></tr>
