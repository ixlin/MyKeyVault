@{
    ViewData["Title"] = "系统设置";
    var config = ViewBag.TushareConfig as dynamic;
}

<link rel="stylesheet" href="~/css/sap-ui.css" />

<div class="sap-page">
    <div class="container">
        <div class="sap-object-page">
            <div class="sap-object-header">
                <h2>系统设置</h2>
                <div class="subtitle">Tushare API 配置</div>
            </div>

            <div class="sap-toolbar">
                <div></div>
                <div>
                    <a href="@Url.Action("Apps")" class="sap-button sap-button-secondary">返回应用管理</a>
                </div>
            </div>

            <div style="padding: 2rem;">
                <div id="result-message" style="margin-bottom: 15px; display: none;"></div>
                
                <div class="sap-card">
                    <div class="sap-card-header">Tushare 配置</div>
                    
                    <div style="margin-top: 1rem;">
                        <!-- Tushare Token -->
                        <div class="sap-form-group">
                            <label class="sap-label">Tushare Token <span style="color: red;">*</span></label>
                            <textarea id="token-input" class="sap-input" placeholder="请输入 Tushare Pro Token" 
                                      style="width: 100%; max-width: 820px; height: 96px; font-family: Menlo, Monaco, Consolas, 'Courier New', monospace;">@(config?.Token ?? "")</textarea>
                            <small class="sap-form-text">从 <a href="https://tushare.pro" target="_blank">Tushare Pro</a> 个人中心获取</small>
                        </div>

                        <!-- Base URL -->
                        <div class="sap-form-group" style="margin-top: 1rem;">
                            <label class="sap-label">Base URL</label>
                            <input id="baseurl-input" type="text" class="sap-input" placeholder="http://api.tushare.pro" 
                                   value="@(config?.BaseUrl ?? "http://api.tushare.pro")" style="width: 100%; max-width: 820px;" />
                            <small class="sap-form-text">Tushare API 基础地址，通常无需修改</small>
                        </div>

                        <!-- JWT Secret -->
                        <div class="sap-form-group" style="margin-top: 1rem;">
                            <label class="sap-label">JWT Secret</label>
                            <div style="display: flex; gap: 10px; max-width: 820px;">
                                <input id="jwtsecret-input" type="text" class="sap-input" placeholder="留空自动生成强密钥" 
                                       value="@(config?.JwtSecret ?? "")" style="flex: 1; font-family: Menlo, Monaco, Consolas, 'Courier New', monospace;" />
                                <button onclick="generateKey('jwtsecret-input')" class="sap-button sap-button-secondary" type="button">生成</button>
                            </div>
                            <small class="sap-form-text">用于生成客户端访问令牌的密钥，留空自动生成</small>
                        </div>

                        <!-- JWT 过期时间 -->
                        <div class="sap-form-group" style="margin-top: 1rem;">
                            <label class="sap-label">Token 有效期（秒）</label>
                            <input id="expires-input" type="number" class="sap-input" placeholder="7200" 
                                   value="@(config?.JwtExpiresInSeconds ?? 7200)" style="width: 200px;" min="60" />
                            <small class="sap-form-text">客户端 Token 的有效期，默认 7200 秒（2小时）</small>
                        </div>

                        <!-- Encryption Key -->
                        <div class="sap-form-group" style="margin-top: 1rem;">
                            <label class="sap-label">Encryption Key</label>
                            <div style="display: flex; gap: 10px; max-width: 820px;">
                                <input id="enckey-input" type="text" class="sap-input" placeholder="留空自动生成强密钥" 
                                       value="@(config?.EncryptionKey ?? "")" style="flex: 1; font-family: Menlo, Monaco, Consolas, 'Courier New', monospace;" />
                                <button onclick="generateKey('enckey-input')" class="sap-button sap-button-secondary" type="button">生成</button>
                            </div>
                            <small class="sap-form-text">用于加密数据库中存储的敏感信息，留空自动生成</small>
                        </div>

                        <!-- 保存按钮 -->
                        <div class="sap-form-group" style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #e0e0e0;">
                            <button onclick="saveSettings()" class="sap-button">保存配置</button>
                            <small class="sap-form-text" style="margin-left: 10px; color: #f57c00;">保存后需要重启服务才能生效</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function saveSettings() {
        const token = document.getElementById('token-input').value.trim();
        const baseUrl = document.getElementById('baseurl-input').value.trim();
        const jwtSecret = document.getElementById('jwtsecret-input').value.trim();
        const expires = parseInt(document.getElementById('expires-input').value) || 7200;
        const encKey = document.getElementById('enckey-input').value.trim();

        if (!token) {
            showMessage('请输入 Tushare Token', 'error');
            return;
        }

        if (!baseUrl) {
            showMessage('请输入 Base URL', 'error');
            return;
        }

        try {
            const response = await fetch('@Url.Action("SaveSettings", "TushareManagement")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    token: token,
                    baseUrl: baseUrl,
                    jwtSecret: jwtSecret || null,
                    jwtExpiresInSeconds: expires,
                    encryptionKey: encKey || null
                })
            });

            const result = await response.json();
            if (result.success) {
                showMessage(result.message, 'success');
            } else {
                showMessage(result.message || '保存失败', 'error');
            }
        } catch (error) {
            showMessage('请求失败: ' + error.message, 'error');
        }
    }

    async function generateKey(inputId) {
        try {
            const response = await fetch('@Url.Action("GenerateKey", "TushareManagement")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const result = await response.json();
            if (result.key) {
                document.getElementById(inputId).value = result.key;
            }
        } catch (error) {
            showMessage('生成密钥失败: ' + error.message, 'error');
        }
    }

    function showMessage(message, type) {
        const div = document.getElementById('result-message');
        div.className = type === 'success' ? 'sap-message sap-message-success' : 'sap-message sap-message-error';
        div.textContent = message;
        div.style.display = 'block';
        
        // 3秒后自动隐藏成功消息
        if (type === 'success') {
            setTimeout(() => {
                div.style.display = 'none';
            }, 3000);
        }
    }
</script>
