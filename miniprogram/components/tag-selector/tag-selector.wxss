.overlay{position:fixed;left:0;top:0;right:0;bottom:0;background:rgba(0,0,0,.35);display:flex;align-items:flex-end;z-index:999}
.sheet{background:#fff;width:100%;border-top-left-radius:16rpx;border-top-right-radius:16rpx;max-height:70vh;}
.header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 24rpx;border-bottom:1rpx solid #eee}
.title{font-size:30rpx;color:#333}
.close{background:#eee;color:#333}
.body{max-height:50vh}
.chips{display:flex;flex-wrap:wrap;gap:12rpx;padding:20rpx}
.chip{display:inline-block;background:#f5f5f5;color:#666;border:2rpx solid transparent;border-radius:20rpx;padding:12rpx 20rpx;font-size:24rpx;transition:all 0.2s ease;}
.chip.active{background:#4caf50;color:white;border-color:#45a049;box-shadow:0 2rpx 8rpx rgba(76, 175, 80, 0.3);}
.footer{display:flex;gap:16rpx;padding:16rpx 24rpx;border-top:1rpx solid #eee}
.btn{flex:1;border-radius:8rpx}
.btn.cancel{background:#f3f4f6;color:#111827}
.btn.ok{background:#07c160;color:#fff}
