.tabbar{position:fixed;left:0;right:0;bottom:0;display:flex;justify-content:space-around;align-items:center;height:120rpx;background:#fff;border-top:1rpx solid #eee;z-index:99}
.item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#333}
.item .icon{font-size:40rpx;line-height:1}
.item .text{font-size:22rpx;margin-top:6rpx}
.item.active{color:#07c160}
