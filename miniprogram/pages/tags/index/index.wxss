.container{padding:12px}
.toolbar{display:flex;gap:8px;align-items:center;margin-bottom:12px}
.input{flex:1;border:1px solid #d1d5db;border-radius:6px;padding:8px;background:#fff}
.list{display:flex;flex-direction:column;gap:8px}
.item{display:flex;justify-content:space-between;align-items:center;border:1px solid #e5e7eb;border-radius:8px;padding:10px 12px;background:#fff}
.name{font-size:15px;color:#111}
.count{font-size:12px;color:#6b7280}
