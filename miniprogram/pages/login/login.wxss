.container{padding:24rpx}
.title{font-size:36rpx;margin-bottom:24rpx}
.input{border:1px solid #ddd;border-radius:8rpx;margin-bottom:16rpx;padding:16rpx}
.btn{background:#1677ff;color:#fff}

/* 调试信息样式 */
.debug-panel {
  background: #fff3cd;
  border: 2px solid #ffc107;
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  font-size: 24rpx;
}

.debug-title {
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  text-align: center;
}

.debug-item {
  display: flex;
  margin-bottom: 12rpx;
  color: #333;
  line-height: 1.6;
}

.debug-label {
  font-weight: bold;
  min-width: 120rpx;
  color: #666;
}

.debug-value {
  flex: 1;
  word-break: break-all;
  color: #333;
}

.debug-item.error {
  background: #fff1f0;
  border: 1px solid #ff4d4f;
  padding: 10rpx;
  border-radius: 4rpx;
  flex-direction: column;
}

.debug-item.error .debug-value {
  color: #ff4d4f;
  font-weight: bold;
  margin-top: 6rpx;
}

.debug-btn {
  background: #722ed1;
  color: #fff;
  font-size: 24rpx;
  padding: 16rpx;
  margin-top: 16rpx;
}

.debug-toggle {
  background: #52c41a;
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
}

/* 链接区域样式 */
.links-container {
  margin-top: 40rpx;
  text-align: center;
}

.hint-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.link-buttons {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 16rpx;
}

.link-text {
  font-size: 28rpx;
  color: #1677ff;
  text-decoration: underline;
  padding: 10rpx 20rpx;
}

.separator {
  font-size: 28rpx;
  color: #ccc;
  margin: 0 20rpx;
}

.website-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.main-title {
  font-size: 36rpx;
  margin-bottom: 24rpx;
  text-align: center;
  font-weight: bold;
}
