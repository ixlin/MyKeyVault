.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  margin-bottom: 30rpx;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.with-eye{padding-right:72rpx}
.input-wrapper{position:relative}
.eye{position:absolute;right:16rpx;top:50%;transform:translateY(-50%);font-size:32rpx;color:#888;padding:8rpx 10rpx;border-radius:8rpx}
.eye:active{background:#eee}

.form-input:focus {
  border-color: #007aff;
  background: white;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #007aff;
  background: white;
}

.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary,
.btn-cancel {
  background: #f8f9fa;
  color: #6c757d;
}

.btn-primary {
  background: #007aff;
  color: white;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #999;
}

.tag-selector-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.no-tags-hint {
  color: #999;
  font-size: 24rpx;
  text-align: center;
  padding: 20rpx;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  background: #f5f5f5;
  color: #666;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  cursor: pointer;
}

.tag-item:active {
  transform: scale(0.95);
}

.tag-item.selected {
  background: #4caf50;
  color: white;
  border-color: #45a049;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

.btn::after {
  border: none;
}
