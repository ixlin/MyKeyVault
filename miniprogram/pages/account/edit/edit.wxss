.container{padding:24rpx;background:#f5f5f5;min-height:100vh;width:100%;}
.field-group{background:#fff;border-radius:12rpx;overflow:hidden;margin-bottom:48rpx;width:100%;}
.container{max-width: 690rpx; margin: 0 auto;} /* 侧边安全边距 */
.field{display:flex;align-items:center;gap:24rpx;padding:24rpx 32rpx;border-bottom:1rpx solid #e5e5e5;position:relative}
.field.top{align-items:flex-start}
.field:last-child{border-bottom:none}
.label{flex:0 0 160rpx;font-size:28rpx;color:#333;font-weight:400}
.input{flex:1;border:1rpx solid #ddd;padding:12rpx 16rpx;width:auto;font-size:28rpx;color:#333;background:#fff;line-height:1.6;border-radius:8rpx}
.textarea{flex:1;border:1rpx solid #ddd;padding:12rpx 16rpx;width:auto;font-size:28rpx;color:#333;background:#fff;min-height:80rpx;line-height:1.6;border-radius:8rpx}
.btn{background:#07c160;color:#fff;border-radius:8rpx;font-size:32rpx;height:88rpx;margin:0 24rpx}
